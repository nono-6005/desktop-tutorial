# Discord ボットトークン（Discord Developer Portal から取得）
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Anthropic API キー（https://console.anthropic.com から取得）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- 以下はオプション（変更しなくてもOK） ---

# プレフィックスコマンドの接頭辞（デフォルト: !）
# COMMAND_PREFIX=!

# デフォルトの要約件数（デフォルト: 50）
# DEFAULT_MESSAGE_COUNT=50

# 最大の要約件数（デフォルト: 200）
# MAX_MESSAGE_COUNT=200

# 使用するClaudeモデル
# SUMMARIZE_MODEL=claude-sonnet-4-6

# 要約の最大トークン数
# MAX_TOKENS=1024
